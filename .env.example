# Copy to .env.local for local dev. Set the same vars in Vercel → Settings →
# Environment Variables (Production / Preview / Development) for deployment.

# --- Required ---

# Supabase project (Settings → API). service_role bypasses RLS — server only,
# never expose to the browser, never commit the real value.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt

# Admin dashboard login. App throws on startup if these are missing.
ADMIN_PASSWORD=change-me
SESSION_SECRET=long-random-string-used-to-sign-the-admin-cookie

# --- Optional: anti-bot (Cloudflare Turnstile) ---
# When unset, forms submit without a challenge. Set both to enable.
# Site key is public (sent to the browser); secret key is server only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Optional: email confirmations (Resend) ---
# When unset, submissions persist but no email is sent.
# EMAIL_FROM must use a domain verified in Resend.
# ADMIN_NOTIFY_EMAIL receives a copy of each submission (optional).
RESEND_API_KEY=
EMAIL_FROM=NetSciX 2027 <noreply@your-verified-domain>
ADMIN_NOTIFY_EMAIL=
